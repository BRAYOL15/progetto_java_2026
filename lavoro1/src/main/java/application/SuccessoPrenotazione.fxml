<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.SuccessoController" style="-fx-background: linear-gradient(to bottom, #1a2980, #26d0ce); -fx-padding: 30;">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40;">

        <Text text="✅ PRENOTAZIONE CONFERMATA!" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #26d0ce;"/>

        <Separator/>

        <VBox spacing="15" alignment="CENTER">
            <Text fx:id="txtMessaggio" style="-fx-font-size: 16px; -fx-fill: #1a2980; -fx-font-weight: bold;" wrappingWidth="600"/>
            <Text fx:id="txtDettagliVolo" style="-fx-font-size: 14px; -fx-fill: #333;" wrappingWidth="600"/>
            <Text fx:id="txtEmailInfo" style="-fx-font-size: 14px; -fx-fill: #26d0ce; -fx-font-weight: bold;" wrappingWidth="600"/>
        </VBox>

        <Separator/>

        <HBox spacing="20" alignment="CENTER">
            <Button text="🏠 TORNA ALLA HOME" onAction="#tornaHome" style="-fx-background-color: #1a2980; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 25;"/>
            <Button text="📋 VISUALIZZA PRENOTAZIONI" onAction="#visualizzaPrenotazioni" style="-fx-background-color: #26d0ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 25;"/>
        </HBox>

    </VBox>
</VBox>