<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Controller" style="-fx-background: linear-gradient(to bottom, #1a2980, #26d0ce); -fx-padding: 30;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Text text="BRADAR PRENOTAZIONI" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: white; -fx-font-family: 'Arial';" />
    <Text text="Prenota il tuo volo in tutta sicurezza" style="-fx-font-size: 16px; -fx-fill: rgba(255,255,255,0.9); -fx-font-family: 'Arial';" />

    <Separator style="-fx-background-color: white; -fx-opacity: 0.5;" />

    <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0.2, 0, 5); -fx-padding: 25;">

        <GridPane hgap="20" vgap="15" alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints percentWidth="30"/>
                <ColumnConstraints percentWidth="40"/>
                <ColumnConstraints percentWidth="30"/>
            </columnConstraints>

            <Label text="Città di Partenza:" style="-fx-font-weight: bold; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="cmbPartenza" promptText="Digita o seleziona città" editable="true" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

            <Label text="Città di Destinazione:" style="-fx-font-weight: bold; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="cmbDestinazione" promptText="Digita o seleziona città" editable="true" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>

            <Button text="🔄 Scambia" fx:id="btnScambia" onAction="#scambiaCitta" style="-fx-background-color: #1a2980; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.rowSpan="2"/>
        </GridPane>

        <GridPane hgap="20" vgap="15">
            <Label text="Data Andata:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <DatePicker fx:id="dateAndata" promptText="Seleziona data" prefWidth="180" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

            <Label text="Data Ritorno:" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <DatePicker fx:id="dateRitorno" promptText="Seleziona data (opzionale)" prefWidth="180" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Passeggeri:" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <ComboBox fx:id="cmbPasseggeri" prefWidth="100" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

            <Label text="Classe:" style="-fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <ComboBox fx:id="cmbClasse" prefWidth="140" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        </GridPane>

        <Separator />

        <HBox spacing="20" alignment="CENTER">
            <Button text="🔍 CERCA VOLI" fx:id="btnCerca" onAction="#cercaVoli" style="-fx-background-color: #26d0ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 12 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
            <Button text="📋 VISUALIZZA PRENOTAZIONI" fx:id="btnVisualizza" onAction="#visualizzaPrenotazioni" style="-fx-background-color: #1a2980; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 20; -fx-background-radius: 25; -fx-cursor: hand;"/>
            <Button text="🗑️ RESET" fx:id="btnReset" onAction="#resetForm" style="-fx-background-color: #ff4757; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 20; -fx-background-radius: 25; -fx-cursor: hand;"/>
        </HBox>

        <VBox spacing="10">
            <Text text="Voli disponibili:" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TableView fx:id="tabellaVoli" prefHeight="250">
                <columns>
                    <TableColumn text="Compagnia" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="compagnia"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Partenza" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="partenza"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Destinazione" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="destinazione"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Data" prefWidth="100">
                        <cellValueFactory><PropertyValueFactory property="data"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Orario" prefWidth="80">
                        <cellValueFactory><PropertyValueFactory property="orario"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Prezzo" prefWidth="80">
                        <cellValueFactory><PropertyValueFactory property="prezzo"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Classe" prefWidth="100">
                        <cellValueFactory><PropertyValueFactory property="classe"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Passeggeri" prefWidth="80">
                        <cellValueFactory><PropertyValueFactory property="passeggeri"/></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>

            <Button text="✈️ PRENOTA SELEZIONATO" fx:id="btnPrenota" onAction="#prenotaVolo" style="-fx-background-color: #26d0ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
        </VBox>

        <VBox spacing="10">
            <Text text="Le tue prenotazioni:" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <ListView fx:id="listaPrenotazioni" prefHeight="150" />
        </VBox>

        <Label fx:id="lblMessaggio" style="-fx-text-fill: #1a2980; -fx-font-weight: bold; -fx-font-size: 12px;"/>
    </VBox>
</VBox>